{
  "name": "digithon-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "smoke": "bun run scripts/smoke.ts",
    "smoke:fill": "bun run scripts/smoke-fill.ts",
    "analyze": "bun run scripts/analyze-files.ts",
    "db:generate": "drizzle-kit generate",
    "templates": "python3 scripts/prepare-templates.py",
    "logos": "python3 scripts/fetch-logos.py"
  },
  "dependencies": {
    "@mastra/core": "^1.41.0",
    "@mastra/loggers": "^1.1.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.11",
    "next": "16.2.7",
    "pdf-lib": "^1.17.1",
    "pdfmake": "^0.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pdfmake": "^0.3.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "better-sqlite3",
    "sharp",
    "unrs-resolver"
  ]
